{
  "name": "@headless-three/renderer",
  "version": "0.1.7",
  "description": "Headless wgpu renderer for Three.js scenes in Node.js. Produces PNG or raw RGBA from a THREE.Scene + THREE.Camera without a browser or WebGL.",
  "keywords": [
    "three",
    "three.js",
    "wgpu",
    "renderer",
    "headless",
    "server-side",
    "ssr",
    "pbr",
    "gltf",
    "vrm",
    "napi",
    "native"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "author": "PortWatcher <jury@skyquakers.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/portwatcher/headless-three-renderer.git",
    "directory": "packages/renderer"
  },
  "bugs": {
    "url": "https://github.com/portwatcher/headless-three-renderer/issues"
  },
  "homepage": "https://github.com/portwatcher/headless-three-renderer#readme",
  "engines": {
    "node": ">=16"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist/",
    "native.js",
    "native.d.ts",
    "README.md",
    "LICENSE"
  ],
  "napi": {
    "binaryName": "headless_three_renderer",
    "packageName": "@headless-three/renderer",
    "dtsHeader": "/// <reference types=\"node\" />\n",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "tsc && napi build --platform --js native.js --dts native.d.ts --release",
    "build:debug": "tsc && napi build --platform --js native.js --dts native.d.ts",
    "build:ts": "tsc",
    "create-npm-dirs": "napi create-npm-dirs",
    "prepublishOnly": "napi prepublish -t npm",
    "pretest": "pnpm run build:ts",
    "test": "pnpm run test:smoke && pnpm run test:gltf && pnpm run test:corpus && pnpm run test:scale && pnpm run test:conformance",
    "test:smoke": "node --test --test-reporter=spec 'test/smoke.test.mjs'",
    "test:gltf": "node --test --test-reporter=spec 'test/gltf.test.mjs'",
    "test:corpus": "node --test --test-reporter=spec 'test/corpus.test.mjs'",
    "test:scale": "node --test --test-reporter=spec 'test/scale.test.mjs'",
    "test:conformance": "node --test --test-reporter=spec 'test/scenes.test.mjs'",
    "test:update": "UPDATE_SNAPSHOTS=1 node --test 'test/**/*.test.mjs'",
    "test:rust": "cargo test",
    "verify:pack": "node scripts/verify-packed-install.mjs"
  },
  "peerDependencies": {
    "three": ">=0.150.0"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.1",
    "@types/node": "25.6.0",
    "three": "^0.172.0",
    "typescript": "6.0.3"
  }
}
