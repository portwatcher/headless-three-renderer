{
  "name": "headless-three-renderer",
  "version": "0.1.0",
  "description": "Headless wgpu renderer for Three.js scenes in Node.js.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "engines": {
    "node": ">=16"
  },
  "files": [
    "dist/",
    "src/",
    "native.js",
    "native.d.ts",
    "*.node",
    "README.md",
    "Cargo.toml",
    "Cargo.lock",
    "build.rs"
  ],
  "napi": {
    "binaryName": "headless_three_renderer",
    "dtsHeader": "/// <reference types=\"node\" />\n",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu"
    ]
  },
  "scripts": {
    "build": "tsc && napi build --platform --js native.js --dts native.d.ts --release",
    "build:debug": "tsc && napi build --platform --js native.js --dts native.d.ts",
    "build:ts": "tsc",
    "test": "cargo test"
  },
  "peerDependencies": {
    "three": ">=0.150.0"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.1",
    "@types/node": "25.6.0",
    "typescript": "6.0.3"
  }
}
