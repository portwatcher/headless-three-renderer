{
  "name": "gltf-renderer-rs",
  "version": "0.1.0",
  "description": "Headless wgpu renderer for Three.js scenes in Node.js.",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT",
  "engines": {
    "node": ">=16"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "native.js",
    "native.d.ts",
    "*.node",
    "README.md",
    "Cargo.toml",
    "Cargo.lock",
    "build.rs",
    "src"
  ],
  "napi": {
    "binaryName": "gltf_renderer_rs",
    "dtsHeader": "/// <reference types=\"node\" />\n",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu"
    ]
  },
  "scripts": {
    "build": "napi build --platform --js native.js --dts native.d.ts --release",
    "build:debug": "napi build --platform --js native.js --dts native.d.ts",
    "test": "cargo test"
  },
  "peerDependencies": {
    "three": ">=0.150.0"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.1"
  }
}
